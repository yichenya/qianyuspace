# 项目配置
SECRET_KEY=qianyu-space-secret-key-2026

# 数据库配置 - PostgreSQL
# 用户名: yang123, 密码: yang123, 数据库名: qianyu, 端口: 5432
DATABASE_URL=postgresql://yang123:yang123@localhost:5432/qianyu

# Redis配置
REDIS_URL=redis://localhost:6379/0

# JWT配置
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS配置
CORS_ORIGINS=["*"]

# 阿里云百炼API配置
ALIYUN_BAILIAN_API_KEY=your-aliyun-bailian-api-key
ALIYUN_BAILIAN_API_URL=https://bailian.aliyuncs.com/api

# 阿里云OSS配置
ALIYUN_OSS_ACCESS_KEY=your-aliyun-oss-access-key
ALIYUN_OSS_SECRET_KEY=your-aliyun-oss-secret-key
ALIYUN_OSS_BUCKET=qianyu-space
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# 邮箱服务配置
EMAIL_API_KEY=your-email-api-key
EMAIL_SENDER=no-reply@qianyu-space.com

# 验证码配置
VERIFICATION_CODE_EXPIRE_MINUTES=5

# 生成任务配置
IMAGE_GENERATION_TIMEOUT=30
VIDEO_GENERATION_TIMEOUT=120